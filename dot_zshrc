# when user input Ctrl-C key, the fzf is stopped by user input,
# I want to implement it, so,
# under cd_from_cwd function is to be exit terminal by reciving Ctrl-C key
# So, I want the function is fzf mode instead of terminal
# What should I rewrite under function?
# 
cd_from_cwd() {
    dir=$(find . -type d | fzf)
    if [[ -n $dir ]]; then
        builtin cd $dir
        pwd
    else
        echo 'please select dir you want to change it.'
        exit 1
    fi
}

# alias fcd="cd_from_cwd"
zle -N cd_from_cwd
bindkey '^k' cd_from_cwd
